<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.AIController"
      style="-fx-padding: 20;">

    <Label text="IA Générateur d'examen" />

    <TextField fx:id="courseField" promptText="Nom du cours" />

    <ComboBox fx:id="levelBox" />

    <Button text="Générer examen IA"
            onAction="#handleGenerate" />

    <TextArea fx:id="resultArea"
              prefHeight="400"
              wrapText="true" />

</VBox>
