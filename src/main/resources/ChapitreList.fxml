<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.ChapitreList"
            style="-fx-background-color:#f0f2f5;">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="15"
              style="-fx-padding:20; -fx-alignment:center_left;">

            <!-- TITLE -->
            <Label text="Liste des Chapitres"
                   style="-fx-font-size:20px; -fx-font-weight:bold;" />

            <Region HBox.hgrow="ALWAYS"/>

            <!-- SEARCH (bigger) -->
            <TextField fx:id="searchField"
                       promptText="Rechercher un chapitre..."
                       style="-fx-pref-width:250; -fx-padding:8; -fx-background-radius:8;" />

            <Button text="🔍"
                    onAction="#searchChapitre"
                    style="-fx-background-color:#007bff; -fx-text-fill:white;" />

            <!-- ADD BUTTON (RIGHT) -->
            <Button text="Ajouter Chapitre"
                    onAction="#goToAdd"
                    style="-fx-background-color:#28a745;
                           -fx-text-fill:white;
                           -fx-background-radius:20;
                           -fx-padding:8 15;" />

        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <ScrollPane fitToWidth="true">
            <FlowPane fx:id="chapitreContainer"
                      hgap="15"
                      vgap="15"
                      style="-fx-padding:20;" />
        </ScrollPane>
    </center>

</BorderPane>
