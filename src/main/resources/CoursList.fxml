<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="700" prefWidth="1100"
      style="-fx-background-color: #f0edf8;"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="tn.esprit.controllers.CoursList">

    <!-- ================= SIDEBAR ================= -->
    <VBox prefWidth="220"
          style="-fx-background-color: #c4b5e8; -fx-padding: 20; -fx-spacing: 10;">

        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 20 0;">
            <Label text="EF"
                   style="-fx-background-color: #7c5cbf; -fx-text-fill: white;
                          -fx-font-weight: bold; -fx-font-size: 16;
                          -fx-background-radius: 10; -fx-padding: 8 10;" />

            <VBox>
                <Label text="EduFlex" style="-fx-font-weight: bold; -fx-font-size: 15;" />
                <Label text="Espace enseignant"
                       style="-fx-font-size: 11; -fx-text-fill: #555;" />
            </VBox>
        </HBox>

        <VBox alignment="CENTER" spacing="5"
              style="-fx-background-color: #d6c9f0; -fx-background-radius: 12; -fx-padding: 15;">

            <Label text="A"
                   style="-fx-background-color: #a08cc8; -fx-text-fill: white;
                          -fx-font-weight: bold; -fx-font-size: 18;
                          -fx-background-radius: 30; -fx-padding: 12 16;" />

            <Label text="Ameni" style="-fx-font-weight: bold; -fx-font-size: 13;" />
            <Label text="Enseignante" style="-fx-font-size: 11; -fx-text-fill: #666;" />
        </VBox>

        <VBox spacing="4" style="-fx-padding: 10 0 0 0;">
            <Button text="DB  Tableau de bord" maxWidth="Infinity" onAction="#goDashboard"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="FO  Forum" maxWidth="Infinity" onAction="#goForum"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="C   Cours" maxWidth="Infinity"
                    style="-fx-background-color: #b39ddb; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="RS  Ressources" maxWidth="Infinity" onAction="#goRessources"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="CT  Categories" maxWidth="Infinity" onAction="#goCategories"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="EX  Examens" maxWidth="Infinity" onAction="#goExamens"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="EV  Evaluations" maxWidth="Infinity" onAction="#goEvaluations"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="RS  Resultats" maxWidth="Infinity" onAction="#goResultats"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="LO  Logout" maxWidth="Infinity" onAction="#goLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
        </VBox>
    </VBox>

    <!-- ================= MAIN ================= -->
    <VBox style="-fx-padding: 30; -fx-background-color: #f5f3fb;"
          spacing="15"
          HBox.hgrow="ALWAYS">

        <!-- ================= WELCOME + IMAGE ================= -->
        <HBox spacing="20"
              style="-fx-background-color: white;
             -fx-padding: 15;
             -fx-background-radius: 12;
             -fx-effect: dropshadow(gaussian, #ddd, 8, 0, 0, 2);">

            <!-- LEFT TEXT -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <ImageView fitWidth="60" fitHeight="60">
                    <image>
                        <Image url="@/images/cours.jpg"/>
                    </image>
                </ImageView>

                <Label text="Bienvenue dans votre espace enseignant"
                       style="-fx-font-size:16px; -fx-font-weight:bold;" />

                <Label text="Suivez vos cours, chapitres et statistiques en temps réel"
                       style="-fx-font-size:12px; -fx-text-fill:#666;" />

                <!-- 🔥 bouton statistiques -->

            </VBox>

            <!-- RIGHT IMAGE -->
            <ImageView fitWidth="140" preserveRatio="true">
                <image>
                    <Image url="@/images/stat.png"/>
                </image>
            </ImageView>
            <Button text="📊 Statistiques"
                    onAction="#goStats"
                    style="-fx-background-color:#9400d3;
                       -fx-text-fill:white;
                       -fx-background-radius:10;
                       -fx-padding:6 12;" />

        </HBox>


        <!-- ================= FLASH NOTIFICATION (Symfony style) ================= -->
        <Label fx:id="notificationLabel"
               visible="false"
               managed="false"
               maxWidth="Infinity"
               style="-fx-background-color:#e8fff0;
                      -fx-text-fill:#1c6b3a;
                      -fx-padding:12 18;
                      -fx-background-radius:12;
                      -fx-font-weight:bold;
                      -fx-font-size:13;
                      -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.10),8,0,0,2);" />

        <!-- ================= SEARCH BAR ================= -->
        <HBox spacing="10" alignment="CENTER_LEFT">

            <Region HBox.hgrow="ALWAYS"/>

            <TextField fx:id="searchField"
                       HBox.hgrow="ALWAYS"
                       maxWidth="400"
                       promptText="Rechercher un cours"
                       style="-fx-padding:8;
                              -fx-background-radius:8;
                              -fx-border-radius:8;
                              -fx-border-color:#ddd;" />

            <Button text="🔍"
                    onAction="#searchCours"
                    style="-fx-background-color:#007bff;
                           -fx-text-fill:white;
                           -fx-background-radius:8;" />
        </HBox>

        <!-- ================= COURSES LIST ================= -->
        <VBox spacing="8" alignment="CENTER_RIGHT">

            <Button text="Ajouter Cour"
                    onAction="#goToAdd"
                    maxWidth="150"
                    style="-fx-background-color:#7c5cbf;
               -fx-text-fill:white;
               -fx-background-radius:20;
               -fx-padding:6 14;
               -fx-font-weight:bold;" />

            <Button fx:id="btnArchives"
                    text="📦 Voir Archives"
                    onAction="#showArchived"
                    maxWidth="150"
                    style="-fx-background-color:#7c5cbf;
               -fx-text-fill:white;
               -fx-background-radius:20;
               -fx-padding:6 14;
               -fx-font-weight:bold;" />
            <Button fx:id="btnVoirCours"
                    text="📦 Voir Cours"
                    onAction="#showAll"
                    maxWidth="150"
                    style="-fx-background-color:#7c5cbf;
               -fx-text-fill:white;
               -fx-background-radius:20;
               -fx-padding:6 14;
               -fx-font-weight:bold;" />

        </VBox>
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent;">


            <FlowPane fx:id="coursContainer"
                      hgap="20"
                      vgap="20"
                      prefWrapLength="800"
                      style="-fx-padding:10;" />

        </ScrollPane>
    </VBox>
</HBox>