<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="700" prefWidth="1100" style="-fx-background-color: #f0edf8;"
      xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="tn.esprit.controllers.EvaluationController">

    <!-- ===== SIDEBAR ===== -->
    <VBox prefWidth="220" style="-fx-background-color: #c4b5e8; -fx-padding: 20;">

        <!-- Logo -->
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 20 0;">
            <Label style="-fx-background-color: #7c5cbf; -fx-text-fill: white;                           -fx-font-weight: bold; -fx-font-size: 16;                           -fx-background-radius: 10; -fx-padding: 8 10;" text="EF" />
            <VBox>
                <Label style="-fx-font-weight: bold; -fx-font-size: 15;" text="EduFlex" />
                <Label style="-fx-font-size: 11; -fx-text-fill: #555;" text="Espace enseignant" />
            </VBox>
        </HBox>

        <!-- Profile -->
        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #d6c9f0; -fx-background-radius: 12;                      -fx-padding: 15; -fx-margin: 0 0 20 0;">
            <Label style="-fx-background-color: #a08cc8; -fx-text-fill: white;                           -fx-font-weight: bold; -fx-font-size: 18;                           -fx-background-radius: 30; -fx-padding: 12 16;" text="ML" />
            <Label style="-fx-font-weight: bold; -fx-font-size: 13;" text="Mme Legrand" />
            <Label style="-fx-font-size: 11; -fx-text-fill: #666;" text="Enseignante" />
        </VBox>

        <!-- Navigation -->
        <VBox spacing="5">
            <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-font-size: 13;" text="DB  Tableau de bord" />
            <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-font-size: 13;" text="FO  Forum" />
            <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-font-size: 13;" text="CL  Mes classes" />
            <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-font-size: 13;" text="C    Cours" />
            <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-font-size: 13;" text="R    Ressources" />
            <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-font-size: 13;" text="EX  Examens" />
            <Button maxWidth="Infinity" style="-fx-background-color: #b39ddb; -fx-alignment: CENTER_LEFT;                            -fx-font-size: 13; -fx-background-radius: 8;" text="EV  Évaluations" />
        </VBox>
    </VBox>

    <!-- ===== MAIN CONTENT ===== -->
    <VBox style="-fx-padding: 40; -fx-background-color: #f5f3fb;" HBox.hgrow="ALWAYS">

        <!-- Card -->
        <VBox spacing="15">

            <!-- TABLE -->
            <TableView fx:id="tableEvaluations">

                <columns>
                    <TableColumn fx:id="colId" text="ID" />
                    <TableColumn fx:id="colNote" text="Note" />
                    <TableColumn fx:id="colAppreciation" text="Appreciation" />
                    <TableColumn fx:id="colExamen" text="Examen" />
                </columns>

            </TableView>

            <!-- FORM -->
            <HBox spacing="10">

                <TextField fx:id="txtNote" promptText="Note" />
                <TextField fx:id="txtAppreciation" promptText="Appreciation" />
                <TextField fx:id="txtExamenId" promptText="Examen ID" />

            </HBox>

            <!-- BUTTONS -->
            <HBox spacing="10">

                <Button text="Ajouter" onAction="#handleAdd"/>
                <Button text="Modifier" onAction="#handleUpdate"/>
                <Button text="Supprimer" onAction="#handleDelete"/>

            </HBox>

        </VBox>
    </VBox>
</HBox>
