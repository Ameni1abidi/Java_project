<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="700" prefWidth="1100" style="-fx-background-color: #f0edf8;"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="tn.esprit.controllers.ExamenController">

    <!-- ===== SIDEBAR (IDENTIQUE) ===== -->
    <VBox prefWidth="220" style="-fx-background-color: #c4b5e8; -fx-padding: 20;">

        <!-- Logo -->
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 20 0;">
            <Label text="EF"
                   style="-fx-background-color: #7c5cbf; -fx-text-fill: white;
                          -fx-font-weight: bold; -fx-font-size: 16;
                          -fx-background-radius: 10; -fx-padding: 8 10;" />
            <VBox>
                <Label text="EduFlex" style="-fx-font-weight: bold; -fx-font-size: 15;" />
                <Label text="Espace enseignant" style="-fx-font-size: 11; -fx-text-fill: #555;" />
            </VBox>
        </HBox>

        <!-- Profile -->
        <VBox alignment="CENTER" spacing="5"
              style="-fx-background-color: #d6c9f0; -fx-background-radius: 12; -fx-padding: 15;">
            <Label text="A"
                   style="-fx-background-color: #a08cc8; -fx-text-fill: white;
                          -fx-font-weight: bold; -fx-font-size: 18;
                          -fx-background-radius: 30; -fx-padding: 12 16;" />
            <Label text="Ameni" style="-fx-font-weight: bold; -fx-font-size: 13;" />
            <Label text="Enseignante" style="-fx-font-size: 11; -fx-text-fill: #666;" />
        </VBox>

        <!-- Navigation -->
        <VBox spacing="5">
            <Button text="DB Tableau de bord" maxWidth="Infinity" styleClass="menu-btn"/>
            <Button text="FO Forum" maxWidth="Infinity" styleClass="menu-btn"/>
            <Button text="CL Mes classes" maxWidth="Infinity" styleClass="menu-btn"/>
            <Button text="C Cours" maxWidth="Infinity" styleClass="menu-btn"/>
            <Button text="R Ressources" maxWidth="Infinity" styleClass="menu-btn"/>

            <!-- ACTIVE -->
            <Button text="EX Examens" maxWidth="Infinity"
                    style="-fx-background-color: #b39ddb; -fx-background-radius: 8;"/>

            <Button text="EV Evaluations" maxWidth="Infinity" styleClass="menu-btn"/>
        </VBox>
    </VBox>

    <!-- ===== MAIN CONTENT ===== -->
    <VBox style="-fx-padding: 40; -fx-background-color: #f5f3fb;" HBox.hgrow="ALWAYS">

        <!-- Card -->
        <VBox spacing="20"
              style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">

            <!-- Header -->
            <HBox>
                <Label text="Examens"
                       style="-fx-font-size: 20; -fx-font-weight: bold;" />

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Créer un examen"
                        fx:id="btnCreate"
                        onAction="#goToCreateExamen"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 10;"/>
            </HBox>

            <!-- TABLE -->
            <TableView fx:id="tableExamens">

                <columns>
                    <TableColumn fx:id="colId" text="ID"/>
                    <TableColumn fx:id="colTitre" text="Titre"/>
                    <TableColumn fx:id="colFichier" text="Fichier"/>
                    <TableColumn fx:id="colType" text="Type"/>
                    <TableColumn fx:id="colDate" text="Date"/>
                    <TableColumn fx:id="colDuree" text="Durée"/>

                    <!-- 🔥 RELATIONS -->
                    <TableColumn fx:id="colCours" text="Cours"/>
                    <TableColumn fx:id="colEnseignant" text="Enseignant"/>

                    <TableColumn fx:id="colActions" text="Actions"/>
                </columns>

            </TableView>

        </VBox>
    </VBox>
</HBox>