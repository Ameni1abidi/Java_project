<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.UserController"
            style="-fx-background-color: linear-gradient(to bottom right, #EDE7F6, #E8F5E9);"
            prefWidth="1280" prefHeight="760">

    <!-- ══ HEADER ══════════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #7E57C2; -fx-padding: 18 30;">
            <VBox spacing="3">
                <Label text="👥  Gestion des Utilisateurs"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                              -fx-text-fill: white;"/>
                <Label text="Administration · EduFlex Platform"
                       style="-fx-font-size: 12px; -fx-text-fill: #CE93D8;"/>
            </VBox>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="countLabel" text="0 utilisateur(s)"
                   style="-fx-background-color: #9575CD; -fx-text-fill: white;
                          -fx-padding: 6 16; -fx-background-radius: 20;
                          -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <Button text="⬅ Retour Home" onAction="#goBack"
                    style="-fx-background-color: white; -fx-text-fill: #5E35B1;
                           -fx-font-size: 12px; -fx-font-weight: bold;
                           -fx-padding: 8 14; -fx-background-radius: 10;
                           -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- ══ CONTENU ══════════════════════════════════════════════════════════ -->
    <center>
        <HBox spacing="18" style="-fx-padding: 20;">

            <!-- ── FORMULAIRE GAUCHE ─────────────────────────────────────── -->
            <VBox spacing="14" minWidth="320" prefWidth="320" maxWidth="340"
                  style="-fx-background-color: white; -fx-padding: 24;
                         -fx-background-radius: 16;
                         -fx-effect: dropshadow(gaussian, rgba(156,120,210,0.2), 12, 0, 0, 4);">

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="➕" style="-fx-font-size: 15px;"/>
                    <Label text="Ajouter un utilisateur"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;
                                  -fx-text-fill: #7E57C2;"/>
                </HBox>

                <Separator style="-fx-background-color: #EDE7F6;"/>

                <!-- Nom -->
                <VBox spacing="4">
                    <Label text="👤  Nom complet *"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-text-fill: #7E57C2;"/>
                    <TextField fx:id="nameField" promptText="Ex : Ahmed Ben Ali"
                               style="-fx-padding: 9 12; -fx-font-size: 13px;
                                      -fx-border-color: #CE93D8; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-background-color: #FAF7FF;"/>
                </VBox>

                <!-- Email -->
                <VBox spacing="4">
                    <Label text="✉  Email *"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-text-fill: #7E57C2;"/>
                    <TextField fx:id="emailField" promptText="email@exemple.com"
                               style="-fx-padding: 9 12; -fx-font-size: 13px;
                                      -fx-border-color: #CE93D8; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-background-color: #FAF7FF;"/>
                </VBox>

                <!-- Mot de passe -->
                <VBox spacing="4">
                    <Label text="🔒  Mot de passe *"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-text-fill: #7E57C2;"/>
                    <PasswordField fx:id="passwordField" promptText="Min. 6 caractères"
                                   style="-fx-padding: 9 12; -fx-font-size: 13px;
                                          -fx-border-color: #CE93D8; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-background-color: #FAF7FF;"/>
                </VBox>

                <!-- Rôle -->
                <VBox spacing="4">
                    <Label text="🎭  Rôle *"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-text-fill: #7E57C2;"/>
                    <ComboBox fx:id="roleAddCombo" maxWidth="Infinity"
                              style="-fx-font-size: 13px; -fx-background-color: #FAF7FF;
                                     -fx-border-color: #CE93D8; -fx-border-radius: 8;
                                     -fx-background-radius: 8;"/>
                </VBox>

                <Separator style="-fx-background-color: #EDE7F6;"/>

                <!-- Bouton Ajouter -->
                <Button text="✅  Ajouter" onAction="#addUser"
                        maxWidth="Infinity"
                        style="-fx-background-color: #7E57C2; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-padding: 11; -fx-background-radius: 10;
                               -fx-cursor: hand;"/>

                <!-- Bouton Supprimer -->
                <Button text="🗑  Supprimer" onAction="#deleteUser"
                        maxWidth="Infinity"
                        style="-fx-background-color: #EF9A9A; -fx-text-fill: #B71C1C;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-padding: 11; -fx-background-radius: 10;
                               -fx-cursor: hand;"/>

                <!-- Bouton Modifier -->
                <Button text="✎  Modifier" onAction="#updateSelectedUser"
                        maxWidth="Infinity"
                        style="-fx-background-color: #90CAF9; -fx-text-fill: #0D47A1;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-padding: 11; -fx-background-radius: 10;
                               -fx-cursor: hand;"/>

                <!-- Bouton Vider -->
                <Button text="✖  Vider" onAction="#clearFields"
                        maxWidth="Infinity"
                        style="-fx-background-color: #F3E5F5; -fx-text-fill: #7E57C2;
                               -fx-font-size: 12px; -fx-font-weight: bold;
                               -fx-padding: 9; -fx-background-radius: 10;
                               -fx-cursor: hand;"/>
            </VBox>

            <!-- ── TABLE + FILTRES DROITE ─────────────────────────────────── -->
            <VBox spacing="12" HBox.hgrow="ALWAYS">

                <!-- Barre recherche + filtre -->
                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-padding: 14 18;
                             -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(156,120,210,0.15), 8, 0, 0, 3);">

                    <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField"
                               promptText="🔍  Rechercher par nom..."
                               prefWidth="260"
                               onKeyReleased="#handleSearch"
                               style="-fx-padding: 9 14; -fx-font-size: 13px;
                                      -fx-border-color: #CE93D8; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-background-color: #FAF7FF;"/>

                    <Separator orientation="VERTICAL"/>

                    <Label text="🎭  Rôle :"
                           style="-fx-font-weight: bold; -fx-text-fill: #7E57C2;
                                  -fx-font-size: 13px;"/>

                    <ComboBox fx:id="filterRoleCombo" prefWidth="180"
                              onAction="#applyFilter"
                              style="-fx-font-size: 13px;"/>

                    <Label text="↕  Tri :"
                           style="-fx-font-weight: bold; -fx-text-fill: #7E57C2;
                                  -fx-font-size: 13px;"/>

                    <ComboBox fx:id="sortCombo" prefWidth="180"
                              onAction="#applySorting"
                              style="-fx-font-size: 13px;"/>

                    <Label text="🎯  Bulk role :"
                           style="-fx-font-weight: bold; -fx-text-fill: #7E57C2;
                                  -fx-font-size: 13px;"/>

                    <ComboBox fx:id="bulkRoleCombo" prefWidth="150"
                              style="-fx-font-size: 13px;"/>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="Appliquer role" onAction="#applyBulkRole" minWidth="130"
                            style="-fx-background-color: #FB8C00; -fx-text-fill: white;
                                   -fx-font-size: 12px; -fx-font-weight: bold;
                                   -fx-padding: 8 14; -fx-background-radius: 8;
                                   -fx-cursor: hand;"/>

                    <Button text="Supprimer selection" onAction="#deleteSelectedUsers" minWidth="150"
                            style="-fx-background-color: #E53935; -fx-text-fill: white;
                                   -fx-font-size: 12px; -fx-font-weight: bold;
                                   -fx-padding: 8 14; -fx-background-radius: 8;
                                   -fx-cursor: hand;"/>

                    <Button text="↺  Réinitialiser" onAction="#loadUsers" minWidth="130"
                            style="-fx-background-color: #43A047; -fx-text-fill: white;
                                   -fx-font-size: 12px; -fx-font-weight: bold;
                                   -fx-padding: 8 14; -fx-background-radius: 8;
                                   -fx-cursor: hand;"/>
                    <Button text="Exporter CSV" onAction="#exportVisibleUsers" minWidth="120"
                            style="-fx-background-color: #1E88E5; -fx-text-fill: white;
                                   -fx-font-size: 12px; -fx-font-weight: bold;
                                   -fx-padding: 8 14; -fx-background-radius: 8;
                                   -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <!-- Statistiques dynamiques -->
                <HBox spacing="10" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-padding: 10 14;
                             -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(156,120,210,0.10), 6, 0, 0, 2);">
                    <Label text="Statistiques (vue actuelle):"
                           style="-fx-text-fill: #7E57C2; -fx-font-weight: bold;"/>
                    <Label text="Total:" style="-fx-text-fill: #6A1B9A;"/>
                    <Label fx:id="totalUsersLabel" text="0" style="-fx-font-weight: bold;"/>
                    <Label text="Admin:" style="-fx-text-fill: #6A1B9A;"/>
                    <Label fx:id="totalAdminsLabel" text="0" style="-fx-font-weight: bold;"/>
                    <Label text="Prof:" style="-fx-text-fill: #6A1B9A;"/>
                    <Label fx:id="totalProfsLabel" text="0" style="-fx-font-weight: bold;"/>
                    <Label text="Etudiant:" style="-fx-text-fill: #6A1B9A;"/>
                    <Label fx:id="totalEtudiantsLabel" text="0" style="-fx-font-weight: bold;"/>
                    <Label text="Parent:" style="-fx-text-fill: #6A1B9A;"/>
                    <Label fx:id="totalParentsLabel" text="0" style="-fx-font-weight: bold;"/>
                </HBox>

                <!-- TableView -->
                <TableView fx:id="table" VBox.vgrow="ALWAYS"
                           style="-fx-background-radius: 12;">
                    <columns>
                        <TableColumn fx:id="colId"    text="ID"
                                     prefWidth="65"   style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colName"  text="👤  Nom"
                                     prefWidth="190"/>
                        <TableColumn fx:id="colEmail" text="✉  Email"
                                     prefWidth="240"/>
                        <TableColumn fx:id="colRole"  text="🎭  Rôle"
                                     prefWidth="160"  style="-fx-alignment: CENTER;"/>
                    </columns>
                    <placeholder>
                        <Label text="Aucun utilisateur trouvé"
                               style="-fx-text-fill: #B39DDB; -fx-font-size: 14px;"/>
                    </placeholder>
                </TableView>

                <HBox alignment="CENTER_RIGHT" style="-fx-padding: 6 0 0 0;">
                    <Pagination fx:id="pagination" maxPageIndicatorCount="7"/>
                </HBox>
            </VBox>
        </HBox>
    </center>

    <!-- ══ FOOTER ═══════════════════════════════════════════════════════════ -->
    <bottom>
        <HBox style="-fx-background-color: #EDE7F6; -fx-padding: 10 24;"
              alignment="CENTER_RIGHT" spacing="10">
            <Label text="EduFlex Admin Panel"
                   style="-fx-text-fill: #9575CD; -fx-font-size: 11px;
                          -fx-font-weight: bold;"/>
            <Label text="·" style="-fx-text-fill: #CE93D8; -fx-font-size: 11px;"/>
            <Label text="Gestion des utilisateurs"
                   style="-fx-text-fill: #CE93D8; -fx-font-size: 11px;"/>
            <Button text="⬅ Retour" onAction="#goBack"/>
        </HBox>
    </bottom>

</BorderPane>
