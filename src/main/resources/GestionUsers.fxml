<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.UserController"
            style="-fx-background-color: #eef2f7;"
            prefWidth="980" prefHeight="700">

    <!-- ══ HEADER ══════════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #1a237e; -fx-padding: 18 30;">
            <VBox spacing="3">
                <Label text="👥  Gestion des Utilisateurs"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                              -fx-text-fill: white;"/>
                <Label text="Administration · EduFlex Platform"
                       style="-fx-font-size: 12px; -fx-text-fill: #9fa8da;"/>
            </VBox>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="countLabel" text="0 utilisateur(s)"
                   style="-fx-background-color: #283593; -fx-text-fill: #e8eaf6;
                          -fx-padding: 6 14; -fx-background-radius: 20;
                          -fx-font-size: 12px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- ══ CONTENU ══════════════════════════════════════════════════════════ -->
    <center>
        <HBox spacing="18" style="-fx-padding: 20;">

            <!-- ── FORMULAIRE GAUCHE ─────────────────────────────────────── -->
            <VBox spacing="14" prefWidth="290"
                  style="-fx-background-color: white; -fx-padding: 24;
                         -fx-background-radius: 14;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 4);">

                <!-- Titre formulaire -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="➕" style="-fx-font-size: 16px;"/>
                    <Label text="Ajouter un utilisateur"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a237e;"/>
                </HBox>

                <Separator style="-fx-background-color: #e8eaf6;"/>

                <!-- Nom -->
                <VBox spacing="5">
                    <Label text="👤  Nom complet *"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-text-fill: #455a64;"/>
                    <TextField fx:id="nameField" promptText="Ex : Ahmed Ben Ali"
                               style="-fx-padding: 10 14; -fx-font-size: 13px;
                                      -fx-border-color: #c5cae9; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-background-color: #f8f9ff;"/>
                </VBox>

                <!-- Email -->
                <VBox spacing="5">
                    <Label text="✉  Email *"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-text-fill: #455a64;"/>
                    <TextField fx:id="emailField" promptText="email@exemple.com"
                               style="-fx-padding: 10 14; -fx-font-size: 13px;
                                      -fx-border-color: #c5cae9; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-background-color: #f8f9ff;"/>
                </VBox>

                <!-- Mot de passe -->
                <VBox spacing="5">
                    <Label text="🔒  Mot de passe *"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-text-fill: #455a64;"/>
                    <PasswordField fx:id="passwordField" promptText="Min. 6 caractères"
                                   style="-fx-padding: 10 14; -fx-font-size: 13px;
                                          -fx-border-color: #c5cae9; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-background-color: #f8f9ff;"/>
                </VBox>

                <!-- Rôle -->
                <VBox spacing="5">
                    <Label text="🎭  Rôle *"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-text-fill: #455a64;"/>
                    <ComboBox fx:id="roleAddCombo" maxWidth="Infinity"
                              style="-fx-font-size: 13px; -fx-background-color: #f8f9ff;
                                     -fx-border-color: #c5cae9; -fx-border-radius: 8;
                                     -fx-background-radius: 8;"/>
                </VBox>

                <Separator style="-fx-background-color: #e8eaf6;"/>

                <!-- Bouton Ajouter -->
                <Button text="✅  Ajouter l'utilisateur" onAction="#addUser"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1a237e; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-padding: 11; -fx-background-radius: 9;
                               -fx-cursor: hand;"/>

                <!-- Bouton Supprimer -->
                <Button text="🗑  Supprimer la sélection" onAction="#deleteUser"
                        maxWidth="Infinity"
                        style="-fx-background-color: #c62828; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-padding: 11; -fx-background-radius: 9;
                               -fx-cursor: hand;"/>

                <!-- Bouton Vider -->
                <Button text="✖  Vider les champs" onAction="#clearFields"
                        maxWidth="Infinity"
                        style="-fx-background-color: #eceff1; -fx-text-fill: #546e7a;
                               -fx-font-size: 12px; -fx-font-weight: bold;
                               -fx-padding: 9; -fx-background-radius: 9;
                               -fx-cursor: hand;"/>
            </VBox>

            <!-- ── TABLE + FILTRES DROITE ─────────────────────────────────── -->
            <VBox spacing="12" HBox.hgrow="ALWAYS">

                <!-- Barre recherche + filtre -->
                <HBox spacing="12" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-padding: 14 18;
                             -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">

                    <!-- Recherche -->
                    <TextField fx:id="searchField" promptText="🔍  Rechercher par nom..."
                               prefWidth="220"
                               onKeyReleased="#handleSearch"
                               style="-fx-padding: 9 14; -fx-font-size: 13px;
                                      -fx-border-color: #c5cae9; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-background-color: #f8f9ff;"/>

                    <Separator orientation="VERTICAL"
                               style="-fx-background-color: #e8eaf6;"/>

                    <!-- Filtre rôle -->
                    <Label text="🎭  Rôle :"
                           style="-fx-font-weight: bold; -fx-text-fill: #455a64;
                                  -fx-font-size: 13px;"/>
                    <ComboBox fx:id="filterRoleCombo" prefWidth="180"
                              onAction="#applyFilter"
                              style="-fx-font-size: 13px;"/>

                    <!-- Bouton reset -->
                    <Button text="↺  Réinitialiser" onAction="#loadUsers"
                            style="-fx-background-color: #e8eaf6; -fx-text-fill: #1a237e;
                                   -fx-font-size: 12px; -fx-font-weight: bold;
                                   -fx-padding: 8 14; -fx-background-radius: 8;
                                   -fx-cursor: hand;"/>
                </HBox>

                <!-- TableView -->
                <TableView fx:id="table" VBox.vgrow="ALWAYS"
                           style="-fx-background-radius: 12;
                                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
                    <columns>
                        <TableColumn fx:id="colId"    text="ID"
                                     prefWidth="65"   style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colName"  text="👤  Nom"
                                     prefWidth="190"/>
                        <TableColumn fx:id="colEmail" text="✉  Email"
                                     prefWidth="240"/>
                        <TableColumn fx:id="colRole"  text="🎭  Rôle"
                                     prefWidth="160"  style="-fx-alignment: CENTER;"/>
                    </columns>
                    <placeholder>
                        <Label text="Aucun utilisateur trouvé"
                               style="-fx-text-fill: #9fa8da; -fx-font-size: 14px;"/>
                    </placeholder>
                </TableView>

            </VBox>
        </HBox>
    </center>

    <!-- ══ FOOTER ═══════════════════════════════════════════════════════════ -->
    <bottom>
        <HBox style="-fx-background-color: #e8eaf6; -fx-padding: 10 24;"
              alignment="CENTER_RIGHT" spacing="10">
            <Label text="EduFlex Admin Panel"
                   style="-fx-text-fill: #7986cb; -fx-font-size: 11px;
                          -fx-font-weight: bold;"/>
            <Label text="·"
                   style="-fx-text-fill: #9fa8da; -fx-font-size: 11px;"/>
            <Label text="Gestion des utilisateurs"
                   style="-fx-text-fill: #9fa8da; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>
