<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.UserController"
            stylesheets="@style.css"
            styleClass="admin-root"
            prefWidth="1280" prefHeight="760">

    <!-- ══ SIDEBAR ═════════════════════════════════════════════════════════ -->
    <left>
        <VBox spacing="14" prefWidth="240" minWidth="220"
              styleClass="admin-sidebar">

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="sidebar-brand">
                <Label text="EduFlex" styleClass="sidebar-title"/>
            </HBox>

            <VBox spacing="8" styleClass="sidebar-menu">
                <Button text="Dashboard Admin" onAction="#goDashboardAdmin" styleClass="sidebar-item"/>
                <Button text="Copilote IA" onAction="#goCopiloteIA" styleClass="sidebar-item"/>
                <Button text="Forum" onAction="#goForum" styleClass="sidebar-item"/>
                <Button text="Utilisateurs" onAction="#goUsers" styleClass="sidebar-item sidebar-item--active"/>
                <Button text="Classes" onAction="#goClasses" styleClass="sidebar-item"/>
                <Button text="Matieres" onAction="#goMatieres" styleClass="sidebar-item"/>
                <Button text="Droits d'acces" onAction="#goAccess" styleClass="sidebar-item"/>
                <Button text="Statistiques" onAction="#goStats" styleClass="sidebar-item"/>
                <Button text="Parametres" onAction="#goSettings" styleClass="sidebar-item"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Logout" onAction="#logoutAdmin" styleClass="sidebar-logout"/>
        </VBox>
    </left>

    <!-- ══ TOPBAR ═══════════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="admin-topbar">
            <VBox spacing="2">
                <Label text="Dashboard Admin" styleClass="topbar-title"/>
                <Label text="Vue globale de la plateforme EduFlex" styleClass="topbar-subtitle"/>
            </VBox>
            <HBox HBox.hgrow="ALWAYS"/>

            <Button text="Nouveau rapport" styleClass="topbar-pill"/>
            <Button text="Logout" onAction="#logoutAdmin" styleClass="topbar-pill topbar-pill--ghost"/>

            <Label fx:id="avatarLabel" text="A" styleClass="topbar-avatar"/>
        </HBox>
    </top>

    <!-- ══ CONTENU ══════════════════════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" styleClass="admin-scroll">
            <content>
                <VBox spacing="16" styleClass="admin-content">

                    <HBox spacing="14" alignment="CENTER_LEFT">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Utilisateurs" styleClass="section-title"/>
                            <Label text="Gestion des utilisateurs" styleClass="section-subtitle"/>
                        </VBox>
                        <Label fx:id="countLabel" text="0 utilisateur(s)" styleClass="count-pill"/>
                        <Button text="Nouveau" styleClass="primary-pill"/>
                    </HBox>

                    <HBox spacing="18">

                        <!-- ── FORMULAIRE GAUCHE ─────────────────────────────── -->
                        <VBox spacing="14" minWidth="320" prefWidth="320" maxWidth="340"
                              styleClass="card">

                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Ajouter un utilisateur" styleClass="card-title"/>
                            </HBox>

                            <Separator styleClass="separator-soft"/>

                            <!-- Nom -->
                            <VBox spacing="4">
                                <Label text="Nom complet *" styleClass="field-label"/>
                                <TextField fx:id="nameField" promptText="Ex : Ahmed Ben Ali" styleClass="field-input"/>
                            </VBox>

                            <!-- Email -->
                            <VBox spacing="4">
                                <Label text="Email *" styleClass="field-label"/>
                                <TextField fx:id="emailField" promptText="email@exemple.com" styleClass="field-input"/>
                            </VBox>

                            <!-- Mot de passe -->
                            <VBox spacing="4">
                                <Label text="Mot de passe *" styleClass="field-label"/>
                                <PasswordField fx:id="passwordField" promptText="Min. 6 caractères" styleClass="field-input"/>
                            </VBox>

                            <!-- Rôle -->
                            <VBox spacing="4">
                                <Label text="Rôle *" styleClass="field-label"/>
                                <ComboBox fx:id="roleAddCombo" maxWidth="Infinity" styleClass="field-select"/>
                            </VBox>

                            <Separator styleClass="separator-soft"/>

                            <!-- Bouton Ajouter -->
                            <Button text="Ajouter" onAction="#addUser" maxWidth="Infinity" styleClass="btn-primary"/>

                            <!-- Bouton Supprimer -->
                            <Button text="Supprimer" onAction="#deleteUser" maxWidth="Infinity" styleClass="btn-danger"/>

                            <!-- Bouton Modifier -->
                            <Button text="Modifier" onAction="#updateSelectedUser" maxWidth="Infinity" styleClass="btn-info"/>

                            <!-- Bouton Vider -->
                            <Button text="Vider" onAction="#clearFields" maxWidth="Infinity" styleClass="btn-muted"/>
                        </VBox>

                        <!-- ── TABLE + FILTRES DROITE ───────────────────────── -->
                        <VBox spacing="12" HBox.hgrow="ALWAYS">

                            <!-- Barre recherche + filtre -->
                            <VBox spacing="10" styleClass="card">

                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <TextField fx:id="searchField"
                                               promptText="Rechercher par nom..."
                                               prefWidth="260"
                                               onKeyReleased="#handleSearch"
                                               styleClass="field-input"/>

                                    <Separator orientation="VERTICAL" styleClass="separator-soft"/>

                                    <Label text="Rôle :" styleClass="field-label"/>
                                    <ComboBox fx:id="filterRoleCombo" prefWidth="180" onAction="#applyFilter" styleClass="field-select"/>

                                    <Label text="Tri :" styleClass="field-label"/>
                                    <ComboBox fx:id="sortCombo" prefWidth="180" onAction="#applySorting" styleClass="field-select"/>

                                    <Label text="Bulk role :" styleClass="field-label"/>
                                    <ComboBox fx:id="bulkRoleCombo" prefWidth="150" styleClass="field-select"/>
                                </HBox>

                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Button text="Appliquer role" onAction="#applyBulkRole" minWidth="130" styleClass="btn-warning"/>
                                    <Button text="Supprimer selection" onAction="#deleteSelectedUsers" minWidth="150" styleClass="btn-danger"/>
                                    <Button text="Réinitialiser" onAction="#loadUsers" minWidth="130" styleClass="btn-success"/>
                                    <Button text="Exporter CSV" onAction="#exportVisibleUsers" minWidth="120" styleClass="btn-primary"/>
                                </HBox>
                            </VBox>

                            <!-- Statistiques dynamiques -->
                            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card card--compact">
                                <Label text="Statistiques (vue actuelle):" styleClass="stat-title"/>
                                <Label text="Total:" styleClass="stat-label"/>
                                <Label fx:id="totalUsersLabel" text="0" styleClass="stat-value"/>
                                <Label text="Admin:" styleClass="stat-label"/>
                                <Label fx:id="totalAdminsLabel" text="0" styleClass="stat-value"/>
                                <Label text="Prof:" styleClass="stat-label"/>
                                <Label fx:id="totalProfsLabel" text="0" styleClass="stat-value"/>
                                <Label text="Etudiant:" styleClass="stat-label"/>
                                <Label fx:id="totalEtudiantsLabel" text="0" styleClass="stat-value"/>
                                <Label text="Parent:" styleClass="stat-label"/>
                                <Label fx:id="totalParentsLabel" text="0" styleClass="stat-value"/>
                            </HBox>

                            <!-- TableView -->
                            <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="admin-table">
                                <columns>
                                    <TableColumn fx:id="colName"  text="NOM" prefWidth="220"/>
                                    <TableColumn fx:id="colEmail" text="EMAIL" prefWidth="260"/>
                                    <TableColumn fx:id="colRole"  text="ROLE" prefWidth="170" style="-fx-alignment: CENTER;"/>
                                </columns>
                                <placeholder>
                                    <Label text="Aucun utilisateur trouvé" styleClass="placeholder-soft"/>
                                </placeholder>
                            </TableView>

                            <HBox alignment="CENTER_RIGHT" style="-fx-padding: 6 0 0 0;">
                                <Pagination fx:id="pagination" maxPageIndicatorCount="7"/>
                            </HBox>

                            <!-- Copilote Admin IA -->
                            <VBox fx:id="copilotSection" spacing="10" styleClass="card">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="Copilote Admin IA" styleClass="card-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="copilotSourceLabel" text="Source: Fallback local" styleClass="badge-soft"/>
                                </HBox>

                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Button text="Analyser avec IA" onAction="#analyzeWithCopilot" styleClass="btn-success"/>
                                    <Button text="Exporter PDF" onAction="#exportCopilotReport" styleClass="btn-muted"/>
                                </HBox>

                                <Label text="Votre question" styleClass="field-label"/>
                                <HBox spacing="10">
                                    <TextField fx:id="copilotQuestionField" promptText="Ex: combien de nouveaux comptes cette semaine ?" HBox.hgrow="ALWAYS" styleClass="field-input"/>
                                    <Button text="Demander" onAction="#askCopilot" styleClass="btn-primary"/>
                                </HBox>

                                <TextArea fx:id="copilotAnswerArea" editable="false" wrapText="true"
                                          prefRowCount="7" styleClass="copilot-area"/>
                            </VBox>

                        </VBox>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <!-- ══ FOOTER ═══════════════════════════════════════════════════════════ -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="admin-footer">
            <Label text="EduFlex Admin" styleClass="footer-text"/>
            <Label text="·" styleClass="footer-dot"/>
            <Label text="Gestion des utilisateurs" styleClass="footer-subtext"/>
        </HBox>
    </bottom>

</BorderPane>
