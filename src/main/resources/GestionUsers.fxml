<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.UserController"
            style="-fx-background-color: #f4f6f9;"
            prefWidth="900" prefHeight="650">

    <!-- ══ HEADER ══════════════════════════════════════════════════════════ -->
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 20 30;">
            <Label text="Gestion des Utilisateurs"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;
                          -fx-text-fill: white;"/>
            <Label text="Administration · EduFlex"
                   style="-fx-font-size: 12px; -fx-text-fill: #95a5a6;"/>
        </VBox>
    </top>

    <!-- ══ CONTENU PRINCIPAL ════════════════════════════════════════════════ -->
    <center>
        <HBox spacing="20" style="-fx-padding: 20;">

            <!-- ── COLONNE GAUCHE : Formulaire ────────────────────────────── -->
            <VBox spacing="14" prefWidth="280"
                  style="-fx-background-color: white; -fx-padding: 24;
                         -fx-border-radius: 10; -fx-background-radius: 10;
                         -fx-border-color: #e0e6ed; -fx-border-width: 1;">

                <Label text="Ajouter un utilisateur"
                       style="-fx-font-size: 15px; -fx-font-weight: bold;
                              -fx-text-fill: #2c3e50;"/>

                <Separator/>

                <!-- Nom -->
                <VBox spacing="4">
                    <Label text="Nom complet *"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-text-fill: #555;"/>
                    <TextField fx:id="nameField" promptText="Ex : Ahmed Ben Ali"
                               style="-fx-padding: 9 12; -fx-font-size: 13px;
                                      -fx-border-color: #dde3ea; -fx-border-radius: 6;
                                      -fx-background-radius: 6;"/>
                </VBox>

                <!-- Email -->
                <VBox spacing="4">
                    <Label text="Email *"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-text-fill: #555;"/>
                    <TextField fx:id="emailField" promptText="email@exemple.com"
                               style="-fx-padding: 9 12; -fx-font-size: 13px;
                                      -fx-border-color: #dde3ea; -fx-border-radius: 6;
                                      -fx-background-radius: 6;"/>
                </VBox>

                <!-- Mot de passe -->
                <VBox spacing="4">
                    <Label text="Mot de passe *"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-text-fill: #555;"/>
                    <PasswordField fx:id="passwordField" promptText="Min. 6 caractères"
                                   style="-fx-padding: 9 12; -fx-font-size: 13px;
                                          -fx-border-color: #dde3ea; -fx-border-radius: 6;
                                          -fx-background-radius: 6;"/>
                </VBox>

                <!-- Rôle -->
                <VBox spacing="4">
                    <Label text="Rôle *"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-text-fill: #555;"/>
                    <ComboBox fx:id="roleAddCombo" maxWidth="Infinity"
                              style="-fx-font-size: 13px;"/>
                </VBox>

                <Separator/>

                <!-- Boutons -->
                <Button text="➕  Ajouter" onAction="#addUser"
                        maxWidth="Infinity"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-padding: 10; -fx-background-radius: 7;
                               -fx-cursor: hand;"/>

                <Button text="🗑  Supprimer la sélection" onAction="#deleteUser"
                        maxWidth="Infinity"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-padding: 10; -fx-background-radius: 7;
                               -fx-cursor: hand;"/>

                <Button text="✖  Vider les champs" onAction="#clearFields"
                        maxWidth="Infinity"
                        style="-fx-background-color: #95a5a6; -fx-text-fill: white;
                               -fx-font-size: 12px; -fx-padding: 8;
                               -fx-background-radius: 7; -fx-cursor: hand;"/>
            </VBox>

            <!-- ── COLONNE DROITE : Table + Filtre ────────────────────────── -->
            <VBox spacing="12" HBox.hgrow="ALWAYS">

                <!-- Barre de filtre -->
                <HBox spacing="12" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-padding: 14 18;
                             -fx-border-radius: 10; -fx-background-radius: 10;
                             -fx-border-color: #e0e6ed; -fx-border-width: 1;">

                    <Label text="Filtrer par rôle :"
                           style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;
                                  -fx-font-size: 13px;"/>

                    <ComboBox fx:id="filterRoleCombo" prefWidth="200"
                              onAction="#applyFilter"
                              style="-fx-font-size: 13px;"/>

                    <Button text="Réinitialiser" onAction="#loadUsers"
                            style="-fx-background-color: #3498db; -fx-text-fill: white;
                                   -fx-font-size: 12px; -fx-padding: 7 14;
                                   -fx-background-radius: 6; -fx-cursor: hand;"/>

                    <!-- Compteur -->
                    <HBox HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT">
                        <Label fx:id="countLabel" text="0 utilisateur(s)"
                               style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
                    </HBox>
                </HBox>

                <!-- TableView -->
                <TableView fx:id="table" VBox.vgrow="ALWAYS"
                           style="-fx-border-radius: 10; -fx-background-radius: 10;
                                  -fx-border-color: #e0e6ed; -fx-border-width: 1;">
                    <columns>
                        <TableColumn fx:id="colId"    text="ID"
                                     prefWidth="60"   style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colName"  text="Nom"
                                     prefWidth="180"/>
                        <TableColumn fx:id="colEmail" text="Email"
                                     prefWidth="230"/>
                        <TableColumn fx:id="colRole"  text="Rôle"
                                     prefWidth="150"  style="-fx-alignment: CENTER;"/>
                    </columns>
                    <placeholder>
                        <Label text="Aucun utilisateur trouvé"
                               style="-fx-text-fill: #95a5a6; -fx-font-size: 14px;"/>
                    </placeholder>
                </TableView>

            </VBox>
        </HBox>
    </center>

    <!-- ══ FOOTER ═══════════════════════════════════════════════════════════ -->
    <bottom>
        <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 10 20;"
              alignment="CENTER_RIGHT">
            <Label text="EduFlex Admin Panel — Gestion des utilisateurs"
                   style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>
