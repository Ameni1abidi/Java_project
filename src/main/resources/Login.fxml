<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.LoginController"
      alignment="CENTER" spacing="16"
      style="-fx-background-color: #f0f4f8;"
      prefWidth="420" prefHeight="480">

    <padding><Insets top="50" right="60" bottom="50" left="60"/></padding>

    <!-- Titre -->
    <Label text="Connexion"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    <Label text="Accédez à votre espace"
           style="-fx-font-size: 13px; -fx-text-fill: #95a5a6;"/>

    <!-- Email -->
    <VBox spacing="5">
        <Label text="Email" style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13px;"/>
        <TextField fx:id="emailField" promptText="votre@email.com"
                   style="-fx-padding: 10 14; -fx-font-size: 14px;
                          -fx-border-color: #dde3ea; -fx-border-radius: 8;
                          -fx-background-radius: 8; -fx-background-color: white;"/>
    </VBox>

    <!-- Mot de passe -->
    <VBox spacing="5">
        <Label text="Mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13px;"/>
        <PasswordField fx:id="passwordField" promptText="••••••••"
                       style="-fx-padding: 10 14; -fx-font-size: 14px;
                              -fx-border-color: #dde3ea; -fx-border-radius: 8;
                              -fx-background-radius: 8; -fx-background-color: white;"/>
    </VBox>

    <!-- Message d'erreur -->
    <Label fx:id="errorLabel" text="" visible="false" wrapText="true"
           style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;"/>

    <!-- Bouton login -->
    <Button text="Se connecter" onAction="#handleLogin"
            maxWidth="Infinity"
            style="-fx-background-color: #3498db; -fx-text-fill: white;
                   -fx-font-size: 15px; -fx-font-weight: bold;
                   -fx-padding: 12; -fx-background-radius: 8;
                   -fx-cursor: hand;"/>

    <!-- Lien register -->
    <HBox alignment="CENTER" spacing="6">
        <Label text="Pas encore de compte ?"
               style="-fx-text-fill: #95a5a6; -fx-font-size: 13px;"/>
        <Button text="S'inscrire" onAction="#handleGoRegister"
                style="-fx-background-color: transparent; -fx-border-color: transparent;
                       -fx-text-fill: #3498db; -fx-font-size: 13px;
                       -fx-cursor: hand; -fx-underline: true;"/>
    </HBox>
</VBox>
