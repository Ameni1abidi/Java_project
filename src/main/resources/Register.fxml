<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.RegisterController"
      alignment="CENTER" spacing="0"
      style="-fx-background-color: linear-gradient(to bottom, #EDE7F6, #E8F5E9);"
      prefWidth="460" prefHeight="660">

    <!-- Card centrale -->
    <VBox alignment="CENTER" spacing="15"
          style="-fx-background-color: white; -fx-padding: 36 48;
                 -fx-background-radius: 20;
                 -fx-effect: dropshadow(gaussian, rgba(156,120,210,0.25), 20, 0, 0, 8);"
          maxWidth="400">

        <!-- Titre -->
        <VBox alignment="CENTER" spacing="6">
            <Label text="✦ EduFlex"
                   style="-fx-font-size: 26px; -fx-font-weight: bold;
                          -fx-text-fill: #7E57C2;"/>
            <Label text="Créer votre compte"
                   style="-fx-font-size: 13px; -fx-text-fill: #B39DDB;"/>
        </VBox>

        <Separator style="-fx-background-color: #EDE7F6;"/>

        <!-- Nom -->
        <VBox spacing="5">
            <Label text="Nom complet *"
                   style="-fx-font-size: 12px; -fx-font-weight: bold;
                          -fx-text-fill: #7E57C2;"/>
            <TextField fx:id="nomField" promptText="Ahmed Ben Ali"
                       style="-fx-padding: 10 14; -fx-font-size: 13px;
                              -fx-border-color: #CE93D8; -fx-border-radius: 10;
                              -fx-background-radius: 10; -fx-background-color: #FAF7FF;"/>
        </VBox>

        <!-- Email -->
        <VBox spacing="5">
            <Label text="Email *"
                   style="-fx-font-size: 12px; -fx-font-weight: bold;
                          -fx-text-fill: #7E57C2;"/>
            <TextField fx:id="emailField" promptText="votre@email.com"
                       style="-fx-padding: 10 14; -fx-font-size: 13px;
                              -fx-border-color: #CE93D8; -fx-border-radius: 10;
                              -fx-background-radius: 10; -fx-background-color: #FAF7FF;"/>
        </VBox>

        <!-- Mot de passe -->
        <VBox spacing="5">
            <Label text="Mot de passe *"
                   style="-fx-font-size: 12px; -fx-font-weight: bold;
                          -fx-text-fill: #7E57C2;"/>
            <PasswordField fx:id="passwordField" promptText="Min. 6 caractères"
                           style="-fx-padding: 10 14; -fx-font-size: 13px;
                                  -fx-border-color: #CE93D8; -fx-border-radius: 10;
                                  -fx-background-radius: 10; -fx-background-color: #FAF7FF;"/>
        </VBox>

        <!-- Confirmer -->
        <VBox spacing="5">
            <Label text="Confirmer le mot de passe *"
                   style="-fx-font-size: 12px; -fx-font-weight: bold;
                          -fx-text-fill: #7E57C2;"/>
            <PasswordField fx:id="confirmField" promptText="Répétez le mot de passe"
                           style="-fx-padding: 10 14; -fx-font-size: 13px;
                                  -fx-border-color: #CE93D8; -fx-border-radius: 10;
                                  -fx-background-radius: 10; -fx-background-color: #FAF7FF;"/>
        </VBox>

        <!-- Rôle -->
        <VBox spacing="5">
            <Label text="Rôle *"
                   style="-fx-font-size: 12px; -fx-font-weight: bold;
                          -fx-text-fill: #7E57C2;"/>
            <ComboBox fx:id="roleCombo" maxWidth="Infinity"
                      style="-fx-font-size: 13px; -fx-background-color: #FAF7FF;
                             -fx-border-color: #CE93D8; -fx-border-radius: 10;
                             -fx-background-radius: 10;"/>
        </VBox>

        <!-- Message feedback -->
        <Label fx:id="messageLabel" text="" visible="false" wrapText="true"
               style="-fx-font-size: 12px; -fx-padding: 8 12;
                      -fx-background-radius: 8;"/>

        <!-- Bouton inscription -->
        <Button text="Créer mon compte" onAction="#handleRegister"
                maxWidth="Infinity"
                style="-fx-background-color: #66BB6A; -fx-text-fill: white;
                       -fx-font-size: 14px; -fx-font-weight: bold;
                       -fx-padding: 13; -fx-background-radius: 12;
                       -fx-cursor: hand;"/>

        <!-- Lien login -->
        <HBox alignment="CENTER" spacing="6">
            <Label text="Déjà inscrit ?"
                   style="-fx-text-fill: #B39DDB; -fx-font-size: 12px;"/>
            <Button text="Se connecter" onAction="#handleGoLogin"
                    style="-fx-background-color: transparent;
                           -fx-border-color: transparent;
                           -fx-text-fill: #7E57C2; -fx-font-size: 12px;
                           -fx-cursor: hand; -fx-underline: true;"/>
        </HBox>
    </VBox>
</VBox>
