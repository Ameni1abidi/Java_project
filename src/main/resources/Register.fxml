<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.RegisterController"
      alignment="CENTER" spacing="14"
      style="-fx-background-color: #f0f4f8;"
      prefWidth="440" prefHeight="600">

    <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

    <!-- Titre -->
    <Label text="Créer un compte"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    <Label text="Rejoignez la plateforme scolaire"
           style="-fx-font-size: 13px; -fx-text-fill: #95a5a6;"/>

    <!-- Nom -->
    <VBox spacing="5">
        <Label text="Nom complet" style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13px;"/>
        <TextField fx:id="nomField" promptText="Ex : Ahmed Ben Ali"
                   style="-fx-padding: 10 14; -fx-font-size: 14px;
                          -fx-border-color: #dde3ea; -fx-border-radius: 8;
                          -fx-background-radius: 8; -fx-background-color: white;"/>
    </VBox>

    <!-- Email -->
    <VBox spacing="5">
        <Label text="Email" style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13px;"/>
        <TextField fx:id="emailField" promptText="votre@email.com"
                   style="-fx-padding: 10 14; -fx-font-size: 14px;
                          -fx-border-color: #dde3ea; -fx-border-radius: 8;
                          -fx-background-radius: 8; -fx-background-color: white;"/>
    </VBox>

    <!-- Mot de passe -->
    <VBox spacing="5">
        <Label text="Mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13px;"/>
        <PasswordField fx:id="passwordField" promptText="Min. 6 caractères"
                       style="-fx-padding: 10 14; -fx-font-size: 14px;
                              -fx-border-color: #dde3ea; -fx-border-radius: 8;
                              -fx-background-radius: 8; -fx-background-color: white;"/>
    </VBox>

    <!-- Confirmation -->
    <VBox spacing="5">
        <Label text="Confirmer le mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13px;"/>
        <PasswordField fx:id="confirmField" promptText="Répétez le mot de passe"
                       style="-fx-padding: 10 14; -fx-font-size: 14px;
                              -fx-border-color: #dde3ea; -fx-border-radius: 8;
                              -fx-background-radius: 8; -fx-background-color: white;"/>
    </VBox>

    <!-- Rôle -->
    <VBox spacing="5">
        <Label text="Rôle" style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13px;"/>
        <ComboBox fx:id="roleCombo" maxWidth="Infinity"
                  style="-fx-font-size: 14px; -fx-background-color: white;
                         -fx-border-color: #dde3ea; -fx-border-radius: 8;
                         -fx-background-radius: 8;"/>
    </VBox>

    <!-- Message feedback -->
    <Label fx:id="messageLabel" text="" visible="false" wrapText="true"
           style="-fx-font-size: 12px;"/>

    <!-- Bouton inscription -->
    <Button text="Créer mon compte" onAction="#handleRegister"
            maxWidth="Infinity"
            style="-fx-background-color: #2ecc71; -fx-text-fill: white;
                   -fx-font-size: 15px; -fx-font-weight: bold;
                   -fx-padding: 12; -fx-background-radius: 8;
                   -fx-cursor: hand;"/>

    <!-- Lien login -->
    <HBox alignment="CENTER" spacing="6">
        <Label text="Déjà inscrit ?"
               style="-fx-text-fill: #95a5a6; -fx-font-size: 13px;"/>
        <Button text="Se connecter" onAction="#handleGoLogin"
                style="-fx-background-color: transparent; -fx-border-color: transparent;
                       -fx-text-fill: #3498db; -fx-font-size: 13px;
                       -fx-cursor: hand; -fx-underline: true;"/>
    </HBox>
</VBox>
