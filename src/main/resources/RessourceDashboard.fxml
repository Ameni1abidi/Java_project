<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="700" prefWidth="1100" style="-fx-background-color: #f5f6fa;"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.RessourceDashboardController">

    <VBox prefWidth="220" style="-fx-background-color: #c4b5e8; -fx-padding: 20; -fx-spacing: 10;">
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 20 0;">
            <Label text="EF"
                   style="-fx-background-color: #7c5cbf; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16; -fx-background-radius: 10; -fx-padding: 8 10;" />
            <VBox>
                <Label text="EduFlex" style="-fx-font-weight: bold; -fx-font-size: 15;" />
                <Label text="Espace enseignant" style="-fx-font-size: 11; -fx-text-fill: #555;" />
            </VBox>
        </HBox>

        <VBox alignment="CENTER" spacing="5"
              style="-fx-background-color: #d6c9f0; -fx-background-radius: 12; -fx-padding: 15;">
            <Label text="A"
                   style="-fx-background-color: #a08cc8; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18; -fx-background-radius: 30; -fx-padding: 12 16;" />
            <Label text="Ameni" style="-fx-font-weight: bold; -fx-font-size: 13;" />
            <Label text="Enseignante" style="-fx-font-size: 11; -fx-text-fill: #666;" />
        </VBox>

        <VBox spacing="4" style="-fx-padding: 10 0 0 0;">
            <Button text="DB  Tableau de bord" maxWidth="Infinity" onAction="#goDashboard"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="FO  Forum" maxWidth="Infinity" onAction="#goForum"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="C   Cours" maxWidth="Infinity" onAction="#goCours"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="RS  Ressources" maxWidth="Infinity" onAction="#goRessources"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="RD  Dashboard ressources" maxWidth="Infinity"
                    style="-fx-background-color: #b39ddb; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="CT  Categories" maxWidth="Infinity" onAction="#goCategories"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="EX  Examens" maxWidth="Infinity" onAction="#goExamens"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="EV  Evaluations" maxWidth="Infinity" onAction="#goEvaluations"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="LO  Logout" maxWidth="Infinity" onAction="#goLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
        </VBox>
    </VBox>

    <VBox spacing="12" style="-fx-padding: 18; -fx-background-color: #f5f6fa;" HBox.hgrow="ALWAYS">
        <GridPane hgap="12" vgap="12">
            <VBox prefWidth="315" prefHeight="335" style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8;">
                <Label text="Engagement par ressource" style="-fx-font-weight: bold; -fx-font-size: 12;" />
                <BarChart fx:id="engagementChart" legendVisible="true" prefHeight="285">
                    <xAxis><CategoryAxis fx:id="engagementXAxis" /></xAxis>
                    <yAxis><NumberAxis fx:id="engagementYAxis" /></yAxis>
                </BarChart>
            </VBox>

            <VBox prefWidth="315" prefHeight="335" GridPane.columnIndex="1" style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8;">
                <Label text="Top ressources par score" style="-fx-font-weight: bold; -fx-font-size: 12;" />
                <BarChart fx:id="topScoreChart" legendVisible="false" prefHeight="285">
                    <xAxis><CategoryAxis fx:id="topScoreXAxis" /></xAxis>
                    <yAxis><NumberAxis fx:id="topScoreYAxis" /></yAxis>
                </BarChart>
            </VBox>

            <VBox prefWidth="315" prefHeight="335" GridPane.columnIndex="2" style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8;">
                <Label text="Repartition des ressources par categorie" style="-fx-font-weight: bold; -fx-font-size: 12;" />
                <PieChart fx:id="categoryPieChart" prefHeight="285" />
            </VBox>

            <VBox prefWidth="315" prefHeight="335" GridPane.rowIndex="1" style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8;">
                <Label text="Evolution des interactions (30 jours)" style="-fx-font-weight: bold; -fx-font-size: 12;" />
                <LineChart fx:id="evolutionChart" legendVisible="true" prefHeight="285">
                    <xAxis><CategoryAxis /></xAxis>
                    <yAxis><NumberAxis /></yAxis>
                </LineChart>
            </VBox>
        </GridPane>
    </VBox>
</HBox>
