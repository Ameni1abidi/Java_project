<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.SidebarController"
      prefWidth="220"
      style="-fx-background-color: #c4b5e8;
             -fx-padding: 20;
             -fx-spacing: 12;">

    <!-- Logo -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 20 0;">
        <Label text="EF"
               style="-fx-background-color: #7c5cbf; -fx-text-fill: white;
                      -fx-font-weight: bold; -fx-font-size: 16;
                      -fx-background-radius: 10; -fx-padding: 8 10;" />
        <VBox>
            <Label text="EduFlex" style="-fx-font-weight: bold; -fx-font-size: 15;" />
            <Label text="Espace enseignant" style="-fx-font-size: 11; -fx-text-fill: #555;" />
        </VBox>
    </HBox>

    <!-- Profile -->
    <VBox alignment="CENTER" spacing="5"
          style="-fx-background-color: #d6c9f0; -fx-background-radius: 12; -fx-padding: 15;">
        <Label text="A"
               style="-fx-background-color: #a08cc8; -fx-text-fill: white;
                      -fx-font-weight: bold; -fx-font-size: 18;
                      -fx-background-radius: 30; -fx-padding: 12 16;" />
        <Label text="Ameni" style="-fx-font-weight: bold; -fx-font-size: 13;" />
        <Label text="Enseignante" style="-fx-font-size: 11; -fx-text-fill: #666;" />
    </VBox>

    <!-- Navigation -->
    <VBox spacing="4" style="-fx-padding: 10 0 0 0;">
        <Button text="DB  Tableau de bord" maxWidth="Infinity" onAction="#goDashboard"
                style="-fx-background-color: transparent; -fx-text-fill: #333;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>

        <Button text="FO  Forum" maxWidth="Infinity" onAction="#goForum"
                style="-fx-background-color: transparent; -fx-text-fill: #333;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>

        <Button text="C   Cours" maxWidth="Infinity" onAction="#goCours"
                style="-fx-background-color: transparent; -fx-text-fill: #333;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>

        <Button text="RS  Ressources" maxWidth="Infinity" onAction="#goRessources"
                style="-fx-background-color: transparent; -fx-text-fill: #333;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>

        <Button text="CT  Categories" maxWidth="Infinity" onAction="#goCategories"
                style="-fx-background-color: transparent; -fx-text-fill: #333;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>

        <!-- ACTIVE -->
        <Button text="EX  Examens" maxWidth="Infinity"
                style="-fx-background-color: #b39ddb; -fx-text-fill: #333;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>

        <Button text="EV  Evaluations" maxWidth="Infinity" onAction="#goEvaluations"
                style="-fx-background-color: transparent; -fx-text-fill: #333;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>

        <Button text="LO  Logout" maxWidth="Infinity" onAction="#goLogout"
                style="-fx-background-color: transparent; -fx-text-fill: #333;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
    </VBox>

</VBox>