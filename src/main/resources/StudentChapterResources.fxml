<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox fx:id="rootContainer" prefHeight="700.0" prefWidth="1220.0" style="-fx-background-color:#eef1ff;"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.StudentChapterResourcesController">

    <VBox fx:id="sidebarContainer" prefWidth="255.0" style="-fx-background-color:#b7a5da; -fx-padding:16; -fx-spacing:12;">
        <VBox fx:id="profileCard" alignment="CENTER" spacing="6" style="-fx-background-color:#c6b6e4; -fx-background-radius:18; -fx-padding:14;">
            <Label fx:id="studentInitialsLabel" text="AM"
                   style="-fx-background-color:#dbd2ee; -fx-text-fill:white; -fx-font-size:28; -fx-font-weight:bold; -fx-background-radius:18; -fx-padding:14 20;" />
            <Label fx:id="studentNameLabel" text="Alex Martin" style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:white;" />
            <Label text="Eleve" style="-fx-font-size:14; -fx-text-fill:#ece9f4;" />
        </VBox>

        <VBox spacing="8" style="-fx-padding:6 0 0 0;">
            <Button text="DB   Tableau de bord" onAction="#goDashboard" maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#f6f4fb; -fx-alignment:CENTER_LEFT; -fx-font-size:15; -fx-padding:10 12;" />
            <Button text="F   Forum" onAction="#goForum" maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#f6f4fb; -fx-alignment:CENTER_LEFT; -fx-font-size:15; -fx-padding:10 12;" />
            <Button text="C   Mes cours" onAction="#goMesCours" maxWidth="Infinity"
                    style="-fx-background-color:white; -fx-text-fill:#42526e; -fx-alignment:CENTER_LEFT; -fx-font-size:15; -fx-padding:10 12; -fx-background-radius:12;" />
            <Button text="EX  Mes examens" onAction="#goExamens" maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#f6f4fb; -fx-alignment:CENTER_LEFT; -fx-font-size:15; -fx-padding:10 12;" />
            <Button text="MS  Messages" maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#f6f4fb; -fx-alignment:CENTER_LEFT; -fx-font-size:15; -fx-padding:10 12;" />
            <Button text="PL  Planning" maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#f6f4fb; -fx-alignment:CENTER_LEFT; -fx-font-size:15; -fx-padding:10 12;" />
        </VBox>
    </VBox>

    <VBox fx:id="mainContainer" HBox.hgrow="ALWAYS" style="-fx-padding:16;">
        <HBox alignment="CENTER_LEFT" spacing="8">
            <VBox>
                <Label fx:id="chapterTitleLabel" text="Ressources du chapitre"
                       style="-fx-font-size:32; -fx-font-weight:bold; -fx-text-fill:#1f2937;" />
                <Label fx:id="chapterMetaLabel" text="Cours: ... | Chapitre: ..."
                       style="-fx-font-size:15; -fx-text-fill:#475467;" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="themeToggleButton" text="Mode sombre" onAction="#toggleTheme"
                    style="-fx-background-color:#111827; -fx-text-fill:#f9fafb; -fx-font-size:13; -fx-font-weight:bold; -fx-background-radius:999; -fx-padding:8 14;" />
            <Button fx:id="favoritesOnlyButton" text="Favoris (0)" onAction="#toggleFavoritesOnly"
                    style="-fx-background-color:#eef2ff; -fx-text-fill:#3730a3; -fx-font-size:13; -fx-font-weight:bold; -fx-background-radius:999; -fx-padding:8 14;" />
            <Button text="Retour au chapitre" onAction="#backToCourses"
                    style="-fx-background-color:#dfe3ff; -fx-text-fill:#4f46e5; -fx-font-size:14; -fx-font-weight:bold; -fx-background-radius:999; -fx-padding:8 14;" />
        </HBox>

        <ScrollPane fitToWidth="true" style="-fx-background-color:transparent; -fx-padding:12 0 0 0;" VBox.vgrow="ALWAYS">
            <content>
                <FlowPane fx:id="cardsContainer" hgap="12" vgap="12" prefWrapLength="900.0" style="-fx-padding:4;">
                    <padding>
                        <Insets top="4" right="4" bottom="16" left="4"/>
                    </padding>
                </FlowPane>
            </content>
        </ScrollPane>
    </VBox>
</HBox>
