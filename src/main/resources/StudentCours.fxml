<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.StudentCours"
            style="-fx-background-color:#f5f7fb;">

    <!-- ================= SIDEBAR ================= -->
    <left>
        <VBox prefWidth="220"
              style="-fx-background-color: #c4b5e8; -fx-padding: 20; -fx-spacing: 10;">

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 20 0;">

                <Label text="EF"
                       style="-fx-background-color: #7c5cbf; -fx-text-fill: white;
                              -fx-font-weight: bold; -fx-font-size: 16;
                              -fx-background-radius: 10; -fx-padding: 8 10;" />

                <VBox>
                    <Label text="EduFlex"
                           style="-fx-font-weight: bold; -fx-font-size: 15;" />
                    <Label text="Espace élève"
                           style="-fx-font-size: 11; -fx-text-fill: #555;" />
                </VBox>

            </HBox>

            <!-- USER -->
            <VBox alignment="CENTER" spacing="5"
                  style="-fx-background-color: #d6c9f0;
                         -fx-background-radius: 12;
                         -fx-padding: 15;">

                <Label text="AM"
                       style="-fx-background-color: #a08cc8;
                              -fx-text-fill: white;
                              -fx-font-weight: bold;
                              -fx-font-size: 18;
                              -fx-background-radius: 30;
                              -fx-padding: 12 16;" />

                <Label text="Alex Martin"
                       style="-fx-font-weight: bold; -fx-font-size: 13;" />

                <Label text="Élève"
                       style="-fx-font-size: 11; -fx-text-fill: #666;" />

            </VBox>

            <!-- MENU -->
            <VBox spacing="4" style="-fx-padding: 10 0 0 0;">

                <Button text="🏠 Tableau de bord"
                        maxWidth="Infinity"
                        onAction="#goDashboard"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #333;
                               -fx-alignment: CENTER_LEFT;
                               -fx-padding: 8 12;"/>

                <Button text="💬 Forum"
                        maxWidth="Infinity"
                        onAction="#goForum"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #333;
                               -fx-alignment: CENTER_LEFT;
                               -fx-padding: 8 12;"/>

                <Button text="📘 Mes cours"
                        maxWidth="Infinity"
                        style="-fx-background-color: #b39ddb;
                               -fx-text-fill: #333;
                               -fx-alignment: CENTER_LEFT;
                               -fx-padding: 8 12;"/>

                <Button text="📝 Examens"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #333;
                               -fx-alignment: CENTER_LEFT;
                               -fx-padding: 8 12;"/>

                <Button text="💬 Messages"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #333;
                               -fx-alignment: CENTER_LEFT;
                               -fx-padding: 8 12;"/>

                <Button text="📅 Planning"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #333;
                               -fx-alignment: CENTER_LEFT;
                               -fx-padding: 8 12;"/>

            </VBox>

        </VBox>
    </left>

    <!-- ================= TOP BAR ================= -->
    <top>
        <HBox spacing="10"
              style="-fx-padding:15;
                     -fx-background-color:white;
                     -fx-alignment:center_left;">

            <Label text="Mes Cours"
                   style="-fx-font-size:22px; -fx-font-weight:bold;" />

        </HBox>
    </top>

    <!-- ================= CENTER CONTENT ================= -->
    <center>

        <VBox spacing="15" style="-fx-padding:15;">

            <!-- TOP WELCOME + WEATHER -->
            <HBox spacing="15"
                  alignment="CENTER_LEFT"
                  style="-fx-background-color:white;
                         -fx-padding:15;
                         -fx-background-radius:15;">

                <ImageView fitWidth="60" fitHeight="60">
                    <image>
                        <Image url="@/images/cours.jpg"/>
                    </image>
                </ImageView>

                <VBox spacing="3">
                    <Label text="Bienvenue dans votre espace étudiant"
                           style="-fx-font-size:16px; -fx-font-weight:bold;"/>

                    <Label text="Continuez vos cours et obtenez vos certificats"
                           style="-fx-font-size:12px; -fx-text-fill:#666;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- WEATHER -->
                <VBox alignment="CENTER"
                      style="-fx-background-color:#f5f3ff;
                             -fx-padding:10;
                             -fx-background-radius:12;">

                    <Label fx:id="weatherIcon" text="☀"/>
                    <Label fx:id="weatherTemp" text="--°C"/>
                    <Label fx:id="weatherDesc" text="Indisponible"/>

                </VBox>

            </HBox>

            <!-- COURSES -->
            <ScrollPane fitToWidth="true"
                        style="-fx-background-color:transparent;">

                <FlowPane fx:id="courseContainer"
                          hgap="20" vgap="20"
                          style="-fx-padding:10;"/>

            </ScrollPane>

        </VBox>

    </center>

</BorderPane>

