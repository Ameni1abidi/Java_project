<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.VoirEvaluationController"
      prefHeight="600" prefWidth="1000"
      style="-fx-background-color: #f4f2fb;">

    <!-- SIDEBAR -->
    <fx:include source="/Sidebar.fxml"/>

    <!-- MAIN -->
    <VBox spacing="25"
          HBox.hgrow="ALWAYS"
          style="-fx-padding: 40;">

        <!-- TITLE -->
        <Label text="Détails de l'évaluation"
               style="-fx-font-size: 28;
                      -fx-font-weight: bold;
                      -fx-text-fill: #2c2c2c;" />

        <!-- CARD -->
        <VBox spacing="20"
              style="-fx-background-color: white;
                     -fx-padding: 30;
                     -fx-background-radius: 16;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 12, 0, 0, 4);">

            <!-- ROW TEMPLATE STYLE -->
            <HBox spacing="15">
                <Label text="ID :" style="-fx-font-weight: bold; -fx-text-fill: #777; -fx-min-width: 120;"/>
                <Label fx:id="lblId" style="-fx-text-fill: #333;"/>
            </HBox>

            <HBox spacing="15">
                <Label text="Note :" style="-fx-font-weight: bold; -fx-text-fill: #777; -fx-min-width: 120;"/>
                <Label fx:id="lblNote"
                       style="-fx-text-fill: #4CAF50;
                              -fx-font-size: 16;
                              -fx-font-weight: bold;"/>
            </HBox>

            <HBox spacing="15">
                <Label text="Appréciation :" style="-fx-font-weight: bold; -fx-text-fill: #777; -fx-min-width: 120;"/>
                <Label fx:id="lblAppreciation" style="-fx-text-fill: #333;"/>
            </HBox>

            <HBox spacing="15">
                <Label text="Examen :" style="-fx-font-weight: bold; -fx-text-fill: #777; -fx-min-width: 120;"/>
                <Label fx:id="lblExamen" style="-fx-text-fill: #333;"/>
            </HBox>

            <HBox spacing="15">
                <Label text="Élève :" style="-fx-font-weight: bold; -fx-text-fill: #777; -fx-min-width: 120;"/>
                <Label fx:id="lblEleve" style="-fx-text-fill: #333;"/>
            </HBox>

        </VBox>

        <!-- ACTIONS -->
        <HBox spacing="12"
              alignment="CENTER_RIGHT">

            <!-- RETOUR -->
            <Button text="← Retour"
                    onAction="#goBack"
                    style="-fx-background-color: #9e9e9e;
                           -fx-text-fill: white;
                           -fx-background-radius: 10;
                           -fx-padding: 10 20;
                           -fx-font-weight: bold;" />

            <!-- MODIFIER -->
            <Button text="✏ Modifier"
                    onAction="#goEdit"
                    style="-fx-background-color: #4CAF50;
                           -fx-text-fill: white;
                           -fx-background-radius: 10;
                           -fx-padding: 10 20;
                           -fx-font-weight: bold;" />

        </HBox>

    </VBox>

</HBox>