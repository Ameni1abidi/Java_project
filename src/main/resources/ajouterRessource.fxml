<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="520.0" prefWidth="720.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.ajouterRessource">
   <children>
      <VBox alignment="TOP_LEFT" layoutX="20.0" layoutY="20.0" prefHeight="480.0" prefWidth="680.0" spacing="15.0">
         <children>
            <Label text="Nouvelle ressource" textFill="#333333">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>

            <VBox spacing="5.0">
               <Label text="TITRE" textFill="#666666">
                  <font>
                     <Font size="12.0" />
                  </font>
               </Label>
               <TextField fx:id="titreField" prefHeight="40.0" promptText="Entrez le titre de la ressource" />
            </VBox>

            <VBox spacing="5.0">
               <Label text="DATE DE DISPONIBILITÉ" textFill="#666666">
                  <font>
                     <Font size="12.0" />
                  </font>
               </Label>
               <DatePicker fx:id="datePicker" prefHeight="40.0" />
            </VBox>

            <VBox spacing="5.0">
               <Label text="CATÉGORIE" textFill="#666666">
                  <font>
                     <Font size="12.0" />
                  </font>
               </Label>
               <ComboBox fx:id="categorieCombo" prefHeight="40.0" promptText="Sélectionnez une catégorie" />
            </VBox>

            <HBox fx:id="fileChooserContainer" spacing="10.0" visible="false">
               <children>
                  <Button fx:id="browseButton" mnemonicParsing="false" onAction="#browseFile" prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;" text="Choisir fichier" />
                  <Label fx:id="selectedFileLabel" alignment="CENTER_LEFT" text="Aucun fichier sélectionné" />
               </children>
            </HBox>

            <VBox fx:id="urlContainer" spacing="5.0" visible="false">
               <Label text="URL DU LIEN" textFill="#666666">
                  <font>
                     <Font size="12.0" />
                  </font>
               </Label>
               <TextField fx:id="urlField" prefHeight="40.0" promptText="https://exemple.com" />
            </VBox>

            <Label fx:id="errorLabel" textFill="red" wrapText="true" />

            <HBox spacing="15.0">
               <Button fx:id="enregistrerButton" mnemonicParsing="false" onAction="#enregistrerRessource" prefHeight="45.0" prefWidth="140.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;" text="Enregistrer" />
               <Button fx:id="supprimerButton" mnemonicParsing="false" onAction="#supprimerRessource" prefHeight="45.0" prefWidth="140.0" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;" text="Supprimer" />
            </HBox>
         </children>
         <padding>
            <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
