<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="tn.esprit.controllers.CategorieController" prefHeight="400.0" prefWidth="600.0">
    <children>
        <VBox spacing="15" AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Nouvelle catégorie" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Retour" prefWidth="80"/>
            </HBox>

            <!-- Form -->
            <VBox spacing="8">
                <Label text="NOM" style="-fx-text-fill: gray;" />
                <TextField fx:id="nomField" prefHeight="35"/>
            </VBox>

            <!-- Button -->
            <Button text="Enregistrer"
                    prefWidth="140"
                    prefHeight="40"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 10;" />
        </VBox>
    </children>

</AnchorPane>
