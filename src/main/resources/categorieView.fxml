<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.CategorieController">

    <children>

        <VBox spacing="150" AnchorPane.topAnchor="90"
              AnchorPane.leftAnchor="60">

            <Label text="Ajouter Catégorie" style="-fx-font-size:89;"/>

            <TextField fx:id="nomField" promptText="Nom catégorie"/>

            <Button text="Enregistrer"
                    onAction="#ajouterCategorie"
                    style="-fx-background-color: green; -fx-text-fill: white;"/>

        </VBox>

    </children>

</AnchorPane>