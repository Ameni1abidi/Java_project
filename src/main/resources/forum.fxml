<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="tn.esprit.controller.AjoutForum"
           style="-fx-background-color:#f5f7fb;">

    <!-- ================== LIST VIEW ================== -->
    <VBox fx:id="listPane" spacing="20" alignment="TOP_CENTER"
          style="-fx-padding:20;">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:10;">

            <VBox>
                <Label text="Forum"
                       style="-fx-font-size:22px; -fx-font-weight:bold;"/>
                <Label text="Discussions de la communauté"
                       style="-fx-text-fill:gray;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Créer un sujet"
                    onAction="#showCreateForm"
                    style="-fx-background-color:#2ecc71; -fx-text-fill:white;"/>
        </HBox>

        <!-- Liste -->
        <ListView fx:id="forumList" prefWidth="500" prefHeight="300"/>

    </VBox>


    <!-- ================== CREATE FORM ================== -->
    <VBox fx:id="formPane" spacing="15" alignment="TOP_LEFT"
          visible="false"
          style="-fx-padding:30;">

        <Label text="Créer un nouveau sujet"
               style="-fx-font-size:22px; -fx-font-weight:bold;" />

        <Label text="Titre"/>
        <TextField fx:id="titreField"/>

        <Label text="Type"/>
        <TextField fx:id="typeField"/>

        <Label text="Contenu"/>
        <TextArea fx:id="contenuField" prefHeight="120"/>

        <HBox spacing="10">
            <Button text="Créer"
                    onAction="#ajouterForum"
                    style="-fx-background-color:#2ecc71; -fx-text-fill:white;"/>

            <Button text="Retour"
                    onAction="#showList"/>
        </HBox>

    </VBox>

</StackPane>