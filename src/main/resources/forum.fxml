<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="700" prefWidth="1100" style="-fx-background-color: #f0edf8;"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="tn.esprit.controllers.AjoutForum">

    <!-- ── Sidebar ── -->
    <VBox prefWidth="220" style="-fx-background-color: #c4b5e8; -fx-padding: 20; -fx-spacing: 10;">
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 20 0;">
            <Label text="EF"
                   style="-fx-background-color: #7c5cbf; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16; -fx-background-radius: 10; -fx-padding: 8 10;" />
            <VBox>
                <Label text="EduFlex" style="-fx-font-weight: bold; -fx-font-size: 15;" />
                <Label text="Espace enseignant" style="-fx-font-size: 11; -fx-text-fill: #555;" />
            </VBox>
        </HBox>

        <VBox alignment="CENTER" spacing="5"
              style="-fx-background-color: #d6c9f0; -fx-background-radius: 12; -fx-padding: 15;">
            <Label text="A"
                   style="-fx-background-color: #a08cc8; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18; -fx-background-radius: 30; -fx-padding: 12 16;" />
            <Label text="Ameni" style="-fx-font-weight: bold; -fx-font-size: 13;" />
            <Label text="Enseignante" style="-fx-font-size: 11; -fx-text-fill: #666;" />
        </VBox>

        <VBox spacing="4" style="-fx-padding: 10 0 0 0;">
            <Button text="DB  Tableau de bord" maxWidth="Infinity" onAction="#goDashboard"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="FO  Forum" maxWidth="Infinity"
                    style="-fx-background-color: #b39ddb; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="C   Cours" maxWidth="Infinity" onAction="#goCours"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="RS  Ressources" maxWidth="Infinity" onAction="#goRessources"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="CT  Categories" maxWidth="Infinity" onAction="#goCategories"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="EX  Examens" maxWidth="Infinity" onAction="#goExamens"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="EV  Evaluations" maxWidth="Infinity" onAction="#goEvaluations"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="RS  Resultats" maxWidth="Infinity" onAction="#goResultats"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
            <Button text="LO  Logout" maxWidth="Infinity" onAction="#goLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8;"/>
        </VBox>
    </VBox>

    <!-- ── Contenu principal ── -->
    <StackPane style="-fx-padding: 40; -fx-background-color: #f5f3fb;" HBox.hgrow="ALWAYS">

        <!-- ── Liste forums ── -->
        <VBox spacing="20"
              style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, #ddd, 8, 0, 0, 2);"
              StackPane.alignment="CENTER">

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox>
                    <Label text="Forum" style="-fx-font-size: 22px; -fx-font-weight:bold;"/>
                    <Label text="Discussions de la communaute" style="-fx-text-fill:#888;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Telecharger Excel" onAction="#exporterExcel"
                        style="-fx-background-color:#1d7a3a; -fx-text-fill:white; -fx-background-radius:20; -fx-font-weight:bold; -fx-padding:8 16;"/>
                <Button text="+ Creer un sujet" onAction="#showCreateForm"
                        style="-fx-background-color:#7c3aed; -fx-text-fill:white; -fx-background-radius:20; -fx-font-weight:bold; -fx-padding:8 16;"/>
            </HBox>

            <ScrollPane fitToWidth="true" style="-fx-background-color:transparent; -fx-border-color:transparent;" VBox.vgrow="ALWAYS">
                <FlowPane fx:id="forumContainer"
                          hgap="24" vgap="24"
                          alignment="CENTER"
                          style="-fx-padding: 10;"/>
            </ScrollPane>

            <HBox spacing="10" alignment="CENTER">
                <Button text="Precedent" onAction="#previousPage"
                        style="-fx-background-color:#7c3aed; -fx-text-fill:white; -fx-background-radius:20; -fx-padding:6 16;"/>
                <Label fx:id="pageLabel"
                       style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#555;"/>
                <Button text="Suivant" onAction="#nextPage"
                        style="-fx-background-color:#7c3aed; -fx-text-fill:white; -fx-background-radius:20; -fx-padding:6 16;"/>
            </HBox>
        </VBox>
        <!-- ── Formulaire création (overlay plein écran) ── -->
        <StackPane fx:id="formOverlay"
                   visible="false"
                   style="-fx-background-color: rgba(0,0,0,0.45);">

            <VBox spacing="0"
                  maxWidth="580"
                  style="-fx-background-color:white; -fx-background-radius:18;
                         -fx-effect: dropshadow(gaussian, #7c3aed, 20, 0.2, 0, 4);"
                  StackPane.alignment="CENTER">
                <!-- Header violet -->
                <VBox spacing="6"
                      style="-fx-background-color: linear-gradient(to bottom, #c4b5fd, #a78bfa);                             -fx-padding: 28 32 24 32;
                             -fx-background-radius: 18 18 0 0;">
                    <Label text="✏  Creer un nouveau sujet"
                           style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:white;"/>
                    <Label text="Remplissez les informations ci-dessous"
                           style="-fx-font-size:12px; -fx-text-fill:#e9d5ff;"/>
                </VBox>

                <!-- Corps du formulaire -->
                <VBox spacing="18" style="-fx-padding: 30 32 28 32;">

                    <!-- Titre -->
                    <VBox spacing="6">
                        <Label text="Titre du sujet"
                               style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#4b5563;"/>
                        <TextField fx:id="titreField"
                                   promptText="Ex: Comment résoudre ce problème ?"
                                   style="-fx-background-color:#f9fafb; -fx-border-color:#d1d5db;
                                          -fx-border-radius:10; -fx-background-radius:10;
                                          -fx-padding:10 14; -fx-font-size:13px;"/>
                    </VBox>

                    <!-- Type -->
                    <VBox spacing="6">
                        <Label text="Type / Catégorie"
                               style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#4b5563;"/>
                        <TextField fx:id="typeField"
                                   promptText="Ex: Question, Discussion, Annonce..."
                                   style="-fx-background-color:#f9fafb; -fx-border-color:#d1d5db;
                                          -fx-border-radius:10; -fx-background-radius:10;
                                          -fx-padding:10 14; -fx-font-size:13px;"/>
                    </VBox>

                    <!-- Contenu -->
                    <VBox spacing="6">
                        <Label text="Contenu"
                               style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#4b5563;"/>
                        <TextArea fx:id="contenuField"
                                  promptText="Décrivez votre sujet en détail..."
                                  prefHeight="120"
                                  wrapText="true"
                                  style="-fx-background-color:#f9fafb; -fx-border-color:#d1d5db;
                                         -fx-border-radius:10; -fx-background-radius:10;
                                         -fx-padding:10 14; -fx-font-size:13px;"/>
                    </VBox>

                    <!-- Boutons -->
                    <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding:8 0 0 0;">
                        <Button text="Annuler" onAction="#showList"
                                style="-fx-background-color:#f3f4f6; -fx-text-fill:#374151;
                                       -fx-background-radius:10; -fx-padding:10 24;
                                       -fx-font-size:13px; -fx-font-weight:bold;
                                       -fx-border-color:#d1d5db; -fx-border-radius:10; -fx-border-width:1;"/>
                        <Button text="✔  Publier le sujet" onAction="#ajouterForum"
                                style="-fx-background-color: linear-gradient(to right, #7c3aed, #a78bfa);
                                       -fx-text-fill:white; -fx-background-radius:10;
                                       -fx-padding:10 24; -fx-font-size:13px; -fx-font-weight:bold;"/>
                    </HBox>
                </VBox>
            </VBox>
        </StackPane>
    </StackPane>
</HBox>