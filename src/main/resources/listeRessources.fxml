<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.control.TextField?>
<AnchorPane prefHeight="600.0" prefWidth="960.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.ResourceListController">
   <children>
      <VBox layoutX="20.0" layoutY="20.0" prefHeight="560.0" prefWidth="920.0" spacing="15.0">
         <children>
            <HBox spacing="10.0" alignment="CENTER_LEFT">
               <children>
                  <Label text="Ressources" textFill="#333333">
                     <font>
                        <Font name="System Bold" size="28.0" />
                     </font>
                  </Label>
                  <Button fx:id="createButton" mnemonicParsing="false" onAction="#onCreateClick" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;" text="Créer" />
               </children>
            </HBox>
            <HBox spacing="10.0" alignment="CENTER_LEFT">
               <children>
                  <TextField fx:id="searchField" promptText="Rechercher une ressource..." prefWidth="520.0" />
                  <Button fx:id="searchButton" mnemonicParsing="false" onAction="#onSearchClick" prefHeight="36.0" prefWidth="120.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;" text="Rechercher" />
               </children>
            </HBox>
            <TableView fx:id="resourceTable" prefHeight="500.0" prefWidth="920.0" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="titreColumn" prefWidth="320.0" text="TITRE" />
                  <TableColumn fx:id="categorieColumn" prefWidth="240.0" text="CATEGORIE" />
                  <TableColumn fx:id="dateColumn" prefWidth="240.0" text="DISPONIBLE LE" />
                  <TableColumn fx:id="actionColumn" prefWidth="160.0" text="ACTIONS" />
               </columns>
            </TableView>
         </children>
         <padding>
            <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
