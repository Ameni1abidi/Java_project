<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.StatistiqueController"
            style="-fx-background-color: #f3f4f6;">

    <!-- ================= SIDEBAR ================= -->
    <left>
        <fx:include source="/Sidebar.fxml"/>
    </left>

    <!-- ================= HEADER ================= -->


    <!-- ================= MAIN ================= -->
    <center>
        <VBox spacing="20" style="-fx-padding: 20;">

            <!-- ================= KPI ================= -->
            <HBox spacing="15">

                <!-- KPI CARD -->
                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10,0,0,5);">
                    <Label text="Moyenne Globale" style="-fx-text-fill: #6b7280;"/>
                    <Label fx:id="lblMoyenneGlobale"
                           style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10,0,0,5);">
                    <Label text="Taux Réussite"/>
                    <Label fx:id="lblTauxReussite" style="-fx-font-size: 22px;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10,0,0,5);">
                    <Label text="Taux Échec"/>
                    <Label fx:id="lblTauxEchec" style="-fx-font-size: 22px;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10,0,0,5);">
                    <Label text="Écart-Type"/>
                    <Label fx:id="lblEcartType" style="-fx-font-size: 22px;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10,0,0,5);">
                    <Label text="Performance"/>
                    <Label fx:id="lblPerformance" style="-fx-font-size: 22px;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10,0,0,5);">
                    <Label text="Note Max"/>
                    <Label fx:id="lblNoteMax" style="-fx-font-size: 22px;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10,0,0,5);">
                    <Label text="Note Min"/>
                    <Label fx:id="lblNoteMin" style="-fx-font-size: 22px;"/>
                </VBox>

            </HBox>

            <!-- ================= CHARTS ================= -->
            <HBox spacing="20">

                <!-- PIE -->
                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10,0,0,5);"
                      HBox.hgrow="ALWAYS">

                    <Label text="📊 Distribution des niveaux"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <PieChart fx:id="pieChart" prefHeight="300"/>
                </VBox>

                <!-- BAR -->
                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10,0,0,5);"
                      HBox.hgrow="ALWAYS">

                    <Label text="📚 Moyenne par examen"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <BarChart fx:id="barChart" prefHeight="300">
                        <xAxis>
                            <CategoryAxis label="Examen"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Note"/>
                        </yAxis>
                    </BarChart>
                </VBox>

            </HBox>

            <!-- ================= INSIGHTS ================= -->
            <HBox spacing="20">

                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10,0,0,5);"
                      HBox.hgrow="ALWAYS">

                    <Label text="👑 Top 3 Élèves"/>
                    <Label fx:id="lblTop3"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10,0,0,5);"
                      HBox.hgrow="ALWAYS">

                    <Label text="⚠️ Examen difficile"/>
                    <Label fx:id="lblExamenDifficile"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10,0,0,5);"
                      HBox.hgrow="ALWAYS">

                    <Label text="📉 Élève en difficulté"/>
                    <Label fx:id="lblEleveDifficulte"/>
                </VBox>

            </HBox>

            <!-- ================= ANALYSE IA ================= -->
            <VBox style="-fx-background-color: #eef2ff; -fx-padding: 20; -fx-background-radius: 15;">

                <Label text="🤖 Analyse intelligente"
                       style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                <Label fx:id="lblAnalyse"
                       style="-fx-font-size: 14px; -fx-text-fill: #1e3a8a;"/>
            </VBox>

        </VBox>
    </center>

</BorderPane>