<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.StatistiqueController"
            style="-fx-background-color: #f5f3ff;">

    <!-- ================= TOP HEADER ================= -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT"
              style="-fx-padding: 15; -fx-background-color: #7c3aed;">
            <Label text="📊 EDUFLEX ANALYTICS DASHBOARD"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- ================= CENTER ================= -->
    <center>
        <VBox spacing="20" style="-fx-padding: 20;">

            <!-- ================= KPI ROW ================= -->
            <HBox spacing="15" alignment="CENTER">

                <VBox style="-fx-background-color: #ede9fe; -fx-padding: 12; -fx-background-radius: 12;">
                    <Label text="Moyenne Globale"/>
                    <Label fx:id="lblMoyenneGlobale" style="-fx-font-size: 18px; -fx-text-fill: #16a34a;"/>
                </VBox>

                <VBox style="-fx-background-color: #ede9fe; -fx-padding: 12; -fx-background-radius: 12;">
                    <Label text="Taux Réussite %"/>
                    <Label fx:id="lblTauxReussite" style="-fx-font-size: 18px; -fx-text-fill: #2563eb;"/>
                </VBox>

                <VBox style="-fx-background-color: #ede9fe; -fx-padding: 12; -fx-background-radius: 12;">
                    <Label text="Taux Échec %"/>
                    <Label fx:id="lblTauxEchec" style="-fx-font-size: 18px; -fx-text-fill: #dc2626;"/>
                </VBox>

                <VBox style="-fx-background-color: #ede9fe; -fx-padding: 12; -fx-background-radius: 12;">
                    <Label text="Écart-Type"/>
                    <Label fx:id="lblEcartType" style="-fx-font-size: 18px; -fx-text-fill: #7c3aed;"/>
                </VBox>

                <VBox style="-fx-background-color: #ede9fe; -fx-padding: 12; -fx-background-radius: 12;">
                    <Label text="Performance Index"/>
                    <Label fx:id="lblPerformance" style="-fx-font-size: 18px; -fx-text-fill: #059669;"/>
                </VBox>

            </HBox>

            <!-- ================= CHARTS ================= -->
            <HBox spacing="20">

                <!-- PIE CHART -->
                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12;"
                      HBox.hgrow="ALWAYS">
                    <Label text="📊 Distribution des niveaux"/>
                    <PieChart fx:id="pieChart" prefHeight="300"/>
                </VBox>

                <!-- BAR CHART -->
                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12;"
                      HBox.hgrow="ALWAYS">
                    <Label text="📚 Moyenne par examen"/>
                    <BarChart fx:id="barChart">
                        <xAxis>
                            <CategoryAxis label="Examen"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Note"/>
                        </yAxis>
                    </BarChart>
                </VBox>

            </HBox>

            <!-- ================= INSIGHTS ================= -->
            <HBox spacing="20">

                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12;"
                      HBox.hgrow="ALWAYS">
                    <Label text="👑 Top 3 Élèves"/>
                    <Label fx:id="lblTop3"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12;"
                      HBox.hgrow="ALWAYS">
                    <Label text="⚠️ Examen le plus difficile"/>
                    <Label fx:id="lblExamenDifficile"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12;"
                      HBox.hgrow="ALWAYS">
                    <Label text="📉 Élève en difficulté"/>
                    <Label fx:id="lblEleveDifficulte"/>
                </VBox>

            </HBox>

        </VBox>
    </center>

</BorderPane>